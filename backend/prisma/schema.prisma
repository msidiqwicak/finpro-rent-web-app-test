generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model booking {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String              @db.Uuid
  room_unit_id String              @db.Uuid
  check_in     DateTime            @db.Date
  check_out    DateTime            @db.Date
  total_price  Decimal             @db.Decimal(12, 2)
  status       booking_status_enum @default(WAITING_FOR_PAYMENT)
  expires_at   DateTime            @db.Timestamptz(6)
  created_at   DateTime            @default(now()) @db.Timestamptz(6)
  room_unit    room_unit           @relation(fields: [room_unit_id], references: [id], onUpdate: NoAction)
  users        users               @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  payment      payment[]
  review       review?
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model payment {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  booking_id   String              @db.Uuid
  amount       Decimal             @db.Decimal(12, 2)
  method       payment_method_enum
  proof_url    String?
  status       payment_status_enum @default(PENDING)
  confirmed_at DateTime?           @db.Timestamptz(6)
  booking      booking             @relation(fields: [booking_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model price_modifier {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  room_type_id   String             @db.Uuid
  start_date     DateTime           @db.Date
  end_date       DateTime           @db.Date
  modifier_type  modifier_type_enum
  modifier_value Decimal            @db.Decimal(12, 2)
  is_available   Boolean?           @default(true)
  reason         String?            @db.VarChar(255)
  room_type      room_type          @relation(fields: [room_type_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model property {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id         String             @db.Uuid
  category_id       String?            @db.Uuid
  name              String             @db.VarChar(255)
  description       String?
  image_url         String?
  address           String
  city              String             @db.VarChar(100)
  province          String             @db.VarChar(100)
  latitude          Float?
  longitude         Float?
  created_at        DateTime           @default(now()) @db.Timestamptz(6)
  updated_at        DateTime           @default(now()) @db.Timestamptz(6)
  deleted_at        DateTime?          @db.Timestamptz(6)
  property_category property_category? @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  tenant            tenant             @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  review            review[]
  room_type         room_type[]

  @@index([city], map: "idx_property_city")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model property_category {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id String     @db.Uuid
  name      String     @db.VarChar(255)
  property  property[]
  tenant    tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model review {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  booking_id   String   @unique @db.Uuid
  user_id      String   @db.Uuid
  property_id  String   @db.Uuid
  rating       Int
  comment      String?
  tenant_reply String?
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  booking      booking  @relation(fields: [booking_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  property     property @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users        users    @relation(fields: [user_id], references: [id], onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model room_type {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  property_id     String           @db.Uuid
  name            String           @db.VarChar(255)
  description     String?
  price_per_night Decimal          @db.Decimal(12, 2)
  capacity        Int              @default(1)
  total_units     Int              @default(0)
  amenities       String[]         @default([])
  image_urls      String[]         @default([])
  price_modifier  price_modifier[]
  property        property         @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  room_unit       room_unit[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model room_unit {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  room_type_id String    @db.Uuid
  unit_number  String    @db.VarChar(50)
  is_active    Boolean?  @default(true)
  booking      booking[]
  room_type    room_type @relation(fields: [room_type_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([room_type_id, unit_number], map: "unique_room_unit_per_type")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tenant {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String              @unique @db.Uuid
  name              String              @db.VarChar(255)
  image_url         String?
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  property          property[]
  property_category property_category[]
  users             users               @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String    @db.VarChar(255)
  email         String    @unique @db.VarChar(255)
  password_hash String?   @db.VarChar(255)
  is_verified   Boolean?  @default(false)
  phone         String?   @db.VarChar(50)
  avatar_url    String?
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime  @default(now()) @db.Timestamptz(6)
  provider      String?   @default("LOCAL") @db.VarChar(50)
  provider_id   String?   @db.VarChar(255)
  booking       booking[]
  review        review[]
  tenant        tenant?
}

enum booking_status_enum {
  WAITING_FOR_PAYMENT
  WAITING_FOR_CONFIRMATION
  CONFIRMED
  CANCELED
}

enum modifier_type_enum {
  PERCENTAGE
  FIXED
}

enum payment_method_enum {
  TRANSFER_BANK
  VIRTUAL_ACCOUNT
  EWALLET
}

enum payment_status_enum {
  PENDING
  SUBMITTED
  CONFIRMED
  REJECTED
}
